if ! op account get &>/dev/null; then
  eval $(op signin)
fi

export MYSQL_PRODUCTION_USER_PWD=`op read "op://Private/MySql Password/password"`
export MYSQL_PRODUCTION_ROOT_USER_PWD=`op read "op://Private/MySql Password/Read Slave 002 Root Password"`
export SNOWFLAKE_CONNECTIONS_DEFAULT_PRIVATE_KEY_RAW=`op read "op://Personal/Snowflake RSA Keys/snowflake_rsa_key.p8"`
